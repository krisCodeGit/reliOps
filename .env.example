# =============================================================================
# ReliOps Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# =============================================================================
# Logging
# =============================================================================
# Standard Python levels: debug | info | warning | error | critical | none
# Writes to logs/app.log with automatic rotation (5 MB, 3 backups).
APP_LOG_LEVEL=info

# =============================================================================
# Asset Cache-Busting & Static File Caching
# =============================================================================
# ASSET_VERSION — Bump on each deploy to force browsers to re-fetch static
# assets (CSS/JS/images). Uses semver so you can track what changed.
# In templates: <link href="/static/style.css?v={{ asset_v }}">
# In dev (--debug), templates are never cached regardless of this value.
# Changing the version refreshes the cache after deployment.
# Admin "Clear all cache" clears server-side caches only; this controls
# browser-side cache invalidation.
ASSET_VERSION=1.0.0

# How long (seconds) browsers and CDN should cache /static/ files.
# 604800 = 7 days. ASSET_VERSION bust ensures updates still land immediately.
STATIC_CACHE_TIMEOUT=604800
