# =============================================================================
# ReliOps Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# =============================================================================
# Logging
# =============================================================================
# Standard Python levels: debug | info | warning | error | critical | none
# Writes to logs/app.log with automatic rotation (5 MB, 3 backups).
APP_LOG_LEVEL=info

# =============================================================================
# AI-Enhanced Insights (optional)
# =============================================================================
# ReliOps works fully without AI enabled. Turn this on for richer, LLM-generated
# reliability recommendations. All service names and identifiers are anonymized
# before being sent to any LLM.

AI_INSIGHTS_ENABLED=false

# Provider: anthropic | openai | local
#
#   anthropic    Anthropic Claude API (requires AI_API_KEY)
#   openai       OpenAI GPT API (requires AI_API_KEY)
#   local        Self-hosted LLM on your own infrastructure.
#                Nothing leaves your network. No API key required unless
#                your local endpoint uses one. Set AI_BASE_URL to your
#                model endpoint (e.g. http://localhost:8000).
#                Works with any OpenAI-compatible API (Ollama, vLLM,
#                llama.cpp server, LocalAI, LM Studio, etc.)
#
AI_PROVIDER=none

# API key (required for anthropic and openai, not needed for local)
AI_API_KEY=

# Model name (optional, sensible defaults per provider)
#   anthropic default: claude-sonnet-4-20250514
#   openai default:    gpt-4o-mini  (cost-effective, great for structured insights)
#                      gpt-4o       (upgrade if you want deeper analysis)
#   local:             set to whatever model name your endpoint expects
AI_MODEL=

# Base URL for local provider (ignored for anthropic/openai)
# Examples:
#   Ollama:      http://localhost:11434
#   vLLM:        http://localhost:8000
#   LM Studio:   http://localhost:1234
#   LocalAI:     http://localhost:8080
AI_BASE_URL=

# Timeout in seconds before falling back to pattern-based insights
AI_TIMEOUT=5
